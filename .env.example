# LexAI — environment config
#
# Choose ONE provider path below. Copy this file to `.env` and fill in the key.
# .env is gitignored — safe to put secrets in.

# ============ OPTION 1 — OpenRouter (one key, many providers) ============
# Sign up at https://openrouter.ai → Settings → Create Key
# Model IDs on OpenRouter use the "anthropic/" prefix.

ANTHROPIC_API_KEY=sk-or-v1-PASTE-YOUR-OPENROUTER-KEY-HERE
ANTHROPIC_BASE_URL=https://openrouter.ai/api
LEXAI_MODEL=anthropic/claude-sonnet-4.6
# NOTE: base_url is /api (NOT /api/v1). The Anthropic SDK appends /v1/messages itself.
# Using /api/v1 will 404.

# ============ OPTION 2 — Direct Anthropic (fallback) ============
# Uncomment these if using Anthropic directly; comment out Option 1.
# Sign up at https://console.anthropic.com → API Keys.
#
# ANTHROPIC_API_KEY=sk-ant-PASTE-YOUR-ANTHROPIC-KEY-HERE
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# LEXAI_MODEL=claude-sonnet-4-6
